# `.env` dosyasına kopyalayın ve ortamınıza göre düzenleyin.

# SQLite (varsayılan, dev için yeterli)
DATABASE_URL=sqlite:///./smartattend.db

# PostgreSQL (üretim)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/smartattend

JWT_SECRET=please-change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# Yüz eşleşme toleransı. Düşürmek daha sıkı eşleştirme demektir (genelde 0.45-0.55).
FACE_MATCH_TOLERANCE=0.5

# Web frontend kaynakları. JSON dizi formatı.
# LAN üzerinden telefondan erişeceksen kendi LAN IP'ni de ekle.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
